# ===== SSH (bastion / jumpbox) =====
USE_SSH_TUNNEL=1
SSH_HOST=your-bastion-ip
SSH_PORT=22
SSH_USER=your-user
SSH_KEY_PATH=/keys/id_rsa

# ===== Source MySQL (RDS) =====
DB_HOST=your-rds-endpoint
DB_PORT=3306
DB_USER=your_user
DB_PASSWORD=your_password

# ===== ClickHouse =====
CH_HOST=clickhouse
CH_PORT=8123
CH_USER=warehouse
CH_PASSWORD=warehouse_pass
CH_DB=warehouse

# ===== ETL =====
BATCH_SIZE=5000

# Projects: janela fixa pra não rodar infinito
PROJECTS_LAG_MINUTES=3
